root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
tab_width = 4

[*.{cs,csx}]
# Namespace and using
csharp_style_namespace_declarations = block_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# var preferences — match existing style: var when type is apparent
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-level preferences
csharp_prefer_simple_using_statement = false:none
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

# Braces
csharp_prefer_braces = true:warning

# this. qualification
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Naming conventions
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.camel_case_underscore.required_prefix = _
dotnet_naming_style.camel_case_underscore.capitalization = camel_case

dotnet_naming_rule.constants_should_be_pascal_case.severity = warning
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constants
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const
dotnet_naming_style.pascal_case.capitalization = pascal_case

# Analyzer severities — enabled
dotnet_diagnostic.CA1050.severity = warning
dotnet_diagnostic.CA1310.severity = warning
dotnet_diagnostic.CA1510.severity = warning
dotnet_diagnostic.CA1822.severity = suggestion
dotnet_diagnostic.CA1824.severity = warning
dotnet_diagnostic.CA2208.severity = warning
dotnet_diagnostic.IDE0005.severity = warning

# Analyzer severities — suppressed (not applicable to this project)
dotnet_diagnostic.CA1069.severity = none        # Duplicate enum values: HSP spec has Plugin = Dll
dotnet_diagnostic.CA1304.severity = none        # Specify CultureInfo: decompiler outputs HSP source, not localized text
dotnet_diagnostic.CA1305.severity = none        # Specify IFormatProvider: same rationale
dotnet_diagnostic.CA1311.severity = none        # Specify culture: same rationale
dotnet_diagnostic.CA1711.severity = none        # Identifier ends in Flags: HspCodeExtraFlags matches HSP spec
dotnet_diagnostic.CA1716.severity = none        # Identifier matches keyword: HSP spec names
dotnet_diagnostic.CA1720.severity = none        # Identifier contains type name: HSP enum members (String, Double, Integer)
dotnet_diagnostic.CA1805.severity = none        # Explicit default init: readability preference, fields like `= null` make nullability intent clear
dotnet_diagnostic.CA1830.severity = suggestion  # Prefer strongly typed Append: low priority
dotnet_diagnostic.CA1834.severity = suggestion  # Use StringBuilder.Append(char): low priority
dotnet_diagnostic.CA1859.severity = suggestion  # Use concrete types: may reduce flexibility
dotnet_diagnostic.CA1863.severity = none        # Use char overload: micro-optimization, noisy
dotnet_diagnostic.CA1866.severity = suggestion  # Use char overload of EndsWith: low priority
dotnet_diagnostic.CA2007.severity = none        # ConfigureAwait: not a library
dotnet_diagnostic.CA2201.severity = none        # Do not raise reserved exception types: existing patterns are intentional

[*.{xml,csproj,props,targets,resx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.sh]
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
